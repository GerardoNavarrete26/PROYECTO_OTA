# Ejemplo de contenido de .env

# Puerto de tu servidor Node (si quieres sobreescribir el default 3000)
PORT=3000

# Cadena de conexión de MongoDB (local o Atlas)
MONGO_URI=mongodb://localhost:27017/hotel_reservas
# o
# MONGO_URI=mongodb+srv://usuario:password@cluster0.xxxx.mongodb.net/hotel_reservas

# Claves de API (ejemplo, si usas Booking)
BOOKING_API_KEY=TU_API_KEY_DE_BOOKING